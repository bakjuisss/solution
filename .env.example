# Vercel Environment Variables (Settings → Environment Variables)
# 로컬: .env 파일에 동일 키 설정

GEMINI_API_KEY=your_gemini_api_key

# nb114 문의응대 연동 (HTTPS 전용 — http:// 는 지원하지 않음)
NB114_BASE_URL=https://nb114.co.kr
NB114_API_TOKEN=
NB114_LIST_PATH=/api/inquiries
NB114_AUTH_HEADER=Authorization
NB114_AUTH_SCHEME=Bearer
NB114_FETCH_LIMIT=200
NB114_MAX_PAGES=5
